{
  "schema_version": 1,
  "provider": {
    "active": "openrouter",
    "model": "openrouter/owl-alpha",
    "base_url": "https://openrouter.ai/api/v1",
    "api_key_env": "AGNC_API_KEY",
    "api_key_file": null
  },
  "providers": {
    "openrouter": {
      "gateway": "openrouter",
      "base_url": "https://openrouter.ai/api/v1",
      "api_key_env": "AGNC_API_KEY",
      "default_model": "liquid/lfm-2.5-1.2b-instruct:free"
    }
  },
  "permissions": {
    "mode": "default",
    "always_allow": [],
    "always_deny": [],
    "always_ask": ["shell"]
  },
  "tools": {
    "enabled": ["shell", "read_file", "write_file", "edit_file", "grep", "glob"]
  },
  "runtime": {
    "max_tool_iterations": 25,
    "stream": true,
    "verbose": false
  },
  "paths": {
    "sessions_dir": "~/.agnc/sessions",
    "cache_dir": "~/.agnc/cache"
  }
}
