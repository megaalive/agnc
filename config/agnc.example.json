{
  "schema_version": 1,
  "provider": {
    "active": "openrouter",
    "model": "openrouter/owl-alpha",
    "base_url": "https://openrouter.ai/api/v1",
    "api_key_env": "AGNC_API_KEY",
    "api_key_file": null
  },
  "providers": {
    "openrouter": {
      "gateway": "openrouter",
      "base_url": "https://openrouter.ai/api/v1",
      "api_key_env": "AGNC_API_KEY",
      "default_model": "openrouter/owl-alpha"
    },
    "custom": {
      "gateway": "custom-openai-compatible",
      "base_url": "http://127.0.0.1:8080/v1",
      "api_key_env": "AGNC_API_KEY",
      "default_model": "gpt-4o-mini"
    },
    "opencode": {
      "gateway": "opencode-local",
      "base_url": "http://127.0.0.1:4096/v1",
      "default_model": "opencode/default"
    },
    "ollama": {
      "gateway": "ollama",
      "base_url": "http://127.0.0.1:11434/v1",
      "default_model": "llama3.2"
    },
    "naraya": {
      "gateway": "naraya",
      "base_url": "https://api.naraya.ai/v1",
      "api_key_env": "NARAYA_API_KEY",
      "default_model": "naraya/default"
    },
    "gemini": {
      "gateway": "gemini",
      "base_url": "https://generativelanguage.googleapis.com/v1beta/openai",
      "api_key_env": "GEMINI_API_KEY",
      "default_model": "gemini-2.0-flash"
    }
  },
  "permissions": {
    "mode": "default",
    "always_allow": [],
    "always_deny": [],
    "always_ask": ["shell", "write_file", "edit_file", "mcp", "web_fetch"]
  },
  "mcp": {
    "servers": [
      {
        "id": "workspace-fs",
        "enabled": true,
        "command": "npx",
        "args": [
          "-y",
          "@modelcontextprotocol/server-filesystem",
          "D:/_2025/Gits/megaalive/agnc"
        ],
        "cwd": null,
        "env": {}
      },
      {
        "id": "second-server",
        "enabled": false,
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-filesystem", "."],
        "cwd": null,
        "env": {}
      }
    ]
  },
  "tools": {
    "enabled": ["shell", "read_file", "write_file", "edit_file", "grep", "glob", "find_symbol", "web_fetch", "todo_write"]
  },
  "skills": {
    "enabled": true,
    "paths": ["~/.agnc/skills", ".agnc/skills"]
  },
  "hooks": {
    "enabled": false,
    "session_start": [],
    "pre_turn": [],
    "post_turn": [],
    "pre_tool": [],
    "post_tool": []
  },
  "runtime": {
    "max_tool_iterations": 25,
    "stream": true,
    "verbose": false
  },
  "paths": {
    "sessions_dir": "~/.agnc/sessions",
    "cache_dir": "~/.agnc/cache"
  }
}
