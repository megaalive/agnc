{
  "id": "gemini",
  "label": "Google Gemini",
  "category": "cloud",
  "default_base_url": "https://generativelanguage.googleapis.com/v1beta/openai",
  "default_model": "gemini-2.0-flash",
  "setup": {
    "requires_auth": true,
    "auth_mode": "api-key",
    "credential_env_vars": ["GEMINI_API_KEY", "GOOGLE_API_KEY", "AGNC_API_KEY"]
  },
  "transport": {
    "kind": "openai-compatible",
    "auth_header": {
      "name": "Authorization",
      "scheme": "bearer"
    },
    "endpoint_path": "/chat/completions",
    "models_endpoint_path": "/models",
    "supports_streaming": true,
    "supports_tool_calls": true
  },
  "catalog": {
    "source": "static",
    "models": [
      {
        "id": "gemini-2.0-flash",
        "api_name": "gemini-2.0-flash",
        "capabilities": {
          "streaming": true,
          "tool_calls": true,
          "reasoning": false
        }
      }
    ]
  }
}
