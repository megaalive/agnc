{
  "id": "openrouter",
  "label": "OpenRouter",
  "category": "aggregating",
  "default_base_url": "https://openrouter.ai/api/v1",
  "default_model": "openrouter/owl-alpha",
  "setup": {
    "requires_auth": true,
    "auth_mode": "api-key",
    "credential_env_vars": ["OPENROUTER_API_KEY", "AGNC_API_KEY"]
  },
  "transport": {
    "kind": "openai-compatible",
    "auth_header": {
      "name": "Authorization",
      "scheme": "bearer"
    },
    "endpoint_path": "/chat/completions",
    "models_endpoint_path": "/models",
    "supports_streaming": true,
    "supports_tool_calls": true
  },
  "catalog": {
    "source": "static",
    "models": [
      {
        "id": "owl-alpha",
        "api_name": "openrouter/owl-alpha",
        "capabilities": {
          "streaming": true,
          "tool_calls": true,
          "reasoning": false
        }
      }
    ]
  }
}
