{
  "id": "opencode-local",
  "label": "OpenCode (lokal)",
  "category": "local",
  "default_base_url": "http://127.0.0.1:4096",
  "default_model": "opencode/big-pickle",
  "setup": {
    "requires_auth": false,
    "auth_mode": "basic",
    "credential_env_vars": ["OPENCODE_SERVER_PASSWORD"]
  },
  "transport": {
    "kind": "opencode-native",
    "auth_header": {
      "name": "Authorization",
      "scheme": "basic"
    },
    "endpoint_path": "/session/{sessionID}/message",
    "models_endpoint_path": "/config/providers",
    "supports_streaming": false,
    "supports_tool_calls": false
  },
  "catalog": {
    "source": "dynamic",
    "models": []
  }
}
